# ─── MindfulPath Backend (.env) ────────────────────────────────────────────

# In-house JWT secret (legacy compatibility; generate a strong random string for production)
SECRET_KEY=change-me-in-production-use-long-random-string
ALGORITHM=HS256

# Database
DATABASE_URL=sqlite:///./mental_wellness.db
# Production PostgreSQL:
# DATABASE_URL=postgresql://user:pass@host:5432/mental_wellness

# CORS (comma-separated list of allowed frontend origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# AI Provider
AI_PROVIDER=mock
# Uncomment for OpenAI integration:
# OPENAI_API_KEY=sk-...

# ─── Clerk JWT Verification (REQUIRED for production auth) ─────────────────
# Find this URL in Clerk Dashboard > API Keys > Advanced
# Format: https://<your-clerk-frontend-api-url>/.well-known/jwks.json
CLERK_JWKS_URL=https://settling-walleye-68.clerk.accounts.dev/.well-known/jwks.json
